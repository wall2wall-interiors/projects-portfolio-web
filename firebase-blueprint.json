{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "An interior design project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "year": { "type": "string" },
        "client": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "thumbnail": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "youtubeUrl": { "type": "string" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "year", "client", "location", "description", "thumbnail", "images"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of interior design projects."
    }
  }
}
